# Environment Variables for CleanRoute-AI Backend

# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,your-app.onrender.com

# Database Settings (for PostgreSQL on Render)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=cleanroute_db
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=your-db-host
DB_PORT=5432

# CORS for frontend
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend.netlify.app

# Optional: For local development
# DB_ENGINE=django.db.backends.sqlite3
